                  {
                      "id":  "ag-03-prepara",
                      "name":  "Prepara Janela",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       500,
                                       180
                                   ],
                      "parameters":  {
                                         "jsCode":  "const data = $json.body;\nconst telefone = data.telefone;\nconst nome = data.nome;\nconst email = data.email || \u0027\u0027;\n\nconst OFFSET_MS = 3 * 60 * 60 * 1000;\nconst agora = new Date();\n\n// Calcular inicio de amanha em BRT\nconst agoraBRT = new Date(agora.getTime() - OFFSET_MS);\nconst amanhaBRT = new Date(agoraBRT);\namanhaBRT.setDate(amanhaBRT.getDate() + 1);\namanhaBRT.setHours(0, 0, 0, 0);\n\n// Converter de volta para UTC\nconst inicioJanela = new Date(amanhaBRT.getTime() + OFFSET_MS);\nconst fimJanela = new Date(inicioJanela.getTime() + 7 * 24 * 60 * 60 * 1000);\n\nreturn [{\n  json: {\n    telefone,\n    nome,\n    janelaInicio: inicioJanela.toISOString(),\n    janelaFim: fimJanela.toISOString(),\n    email\n  }\n}];"
                                     }
                  },
                  {
                      "id":  "ag-04-google",
                      "name":  "FreeBusy Google Calendar",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       700,
                                       180
                                   ],
                      "parameters":  {
                                         "method":  "POST",
                                         "url":  "https://www.googleapis.com/calendar/v3/freeBusy",
                                         "authentication":  "predefinedCredentialType",
                                         "nodeCredentialType":  "googleApi",
                                         "sendHeaders":  true,
                                         "headerParameters":  {
                                                                  "parameters":  [
                                                                                     {
                                                                                         "name":  "content-type",
                                                                                         "value":  "application/json"
                                                                                     }
                                                                                 ]
                                                              },
                                         "sendBody":  true,
                                         "contentType":  "raw",
                                         "rawContentType":  "application/json",
                                         "body":  "={\n  \"timeMin\": \"{{ $json.janelaInicio }}\",\n  \"timeMax\": \"{{ $json.janelaFim }}\",\n  \"timeZone\": \"America/Sao_Paulo\",\n  \"items\": [{\"id\": \"wostki@gmail.com\"}, {\"id\": \"g6bvu0857adrvkpjpupur200vrhl4k97@import.calendar.google.com\"}]\n}",
                                         "options":  {
                                                         "timeout":  15000
                                                     }
                                     },
                      "credentials":  {
                                          "googleApi":  {
                                                            "id":  "jUmtAElnwHr5Tmuu",
                                                            "name":  "Google Calendar SA"
                                                        }
                                      }
                  },
                  {
                      "id":  "ag-06-slots",
                      "name":  "Calcula Slots",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       1100,
                                       180
                                   ],
                      "parameters":  {
                                         "jsCode":  "const OFFSET_MS = 3 * 60 * 60 * 1000;\nconst DURACAO_MS = 60 * 60 * 1000;\n\n// Seg-Sex: 09:30-22:30 | Sab: 09:30-17:00 | Dom: bloqueado\nconst BUSINESS = {\n  1: [9, 30, 22, 30],\n  2: [9, 30, 22, 30],\n  3: [9, 30, 22, 30],\n  4: [9, 30, 22, 30],\n  5: [9, 30, 22, 30],\n  6: [9, 30, 17, 0]\n};\n\nconst preparaData = $(\u0027Prepara Janela\u0027).first().json;\nconst telefone = preparaData.telefone;\nconst nome = preparaData.nome;\nconst janelaInicio = new Date(preparaData.janelaInicio);\nconst janelaFim = new Date(preparaData.janelaFim);\nconst emailLead = preparaData.email || \u0027\u0027;\n\n// Google retorna UTC busy times\nconst googleResp = $(\u0027FreeBusy Google Calendar\u0027).first().json;\nconst OUTLOOK_CAL_ID = \u0027g6bvu0857adrvkpjpupur200vrhl4k97@import.calendar.google.com\u0027;\n\nconst googleCal = (googleResp.calendars \u0026\u0026 (googleResp.calendars[\u0027wostki@gmail.com\u0027] || googleResp.calendars.primary)) || {};\nconst googleBusy = (googleCal.busy || []).map(b =\u003e ({ start: b.start, end: b.end }));\n\n// Eventos do Outlook estao 3h adiantados no Google Calendar — corrige subtraindo OFFSET_MS\nconst outlookCalRaw = (googleResp.calendars \u0026\u0026 googleResp.calendars[OUTLOOK_CAL_ID]) || {};\nconst outlookBusy = (outlookCalRaw.busy || []).map(b =\u003e ({\n  start: new Date(new Date(b.start).getTime() + OFFSET_MS).toISOString(),\n  end:   new Date(new Date(b.end).getTime()   + OFFSET_MS).toISOString()\n}));\n\nconst allBusy = [...googleBusy, ...outlookBusy];\n\nfunction isBusy(slotStart, slotEnd) {\n  return allBusy.some(b =\u003e {\n    const bs = new Date(b.start).getTime();\n    const be = new Date(b.end).getTime();\n    return slotStart.getTime() \u003c be \u0026\u0026 slotEnd.getTime() \u003e bs;\n  });\n}\n\nfunction toBRT(utcDate) { return new Date(utcDate.getTime() - OFFSET_MS); }\nfunction toUTC(brtDate) { return new Date(brtDate.getTime() + OFFSET_MS); }\n\nconst DIAS = [\u0027Dom\u0027, \u0027Seg\u0027, \u0027Ter\u0027, \u0027Qua\u0027, \u0027Qui\u0027, \u0027Sex\u0027, \u0027Sab\u0027];\nconst MESES = [\u0027Jan\u0027, \u0027Fev\u0027, \u0027Mar\u0027, \u0027Abr\u0027, \u0027Mai\u0027, \u0027Jun\u0027, \u0027Jul\u0027, \u0027Ago\u0027, \u0027Set\u0027, \u0027Out\u0027, \u0027Nov\u0027, \u0027Dez\u0027];\n\nconst slots = [];\nlet cursor = new Date(janelaInicio);\n\nwhile (cursor \u003c janelaFim \u0026\u0026 slots.length \u003c 3) {\n  const brtCursor = toBRT(cursor);\n  const diaSemana = brtCursor.getDay();\n\n  if (!BUSINESS[diaSemana]) {\n    const brtNextDay = new Date(brtCursor);\n    brtNextDay.setDate(brtNextDay.getDate() + 1);\n    brtNextDay.setHours(0, 0, 0, 0);\n    cursor = toUTC(brtNextDay);\n    continue;\n  }\n\n  const [hIni, mIni, hFim, mFim] = BUSINESS[diaSemana];\n  const brtDay = new Date(brtCursor);\n  brtDay.setHours(0, 0, 0, 0);\n\n  const brtIniExp = new Date(brtDay);\n  brtIniExp.setHours(hIni, mIni, 0, 0);\n  const brtFimExp = new Date(brtDay);\n  brtFimExp.setHours(hFim, mFim, 0, 0);\n\n  if (brtCursor \u003c brtIniExp) {\n    cursor = toUTC(brtIniExp);\n    continue;\n  }\n\n  if (brtCursor \u003e= brtFimExp) {\n    const brtNextDay = new Date(brtDay);\n    brtNextDay.setDate(brtNextDay.getDate() + 1);\n    brtNextDay.setHours(0, 0, 0, 0);\n    cursor = toUTC(brtNextDay);\n    continue;\n  }\n\n  const slotStart = new Date(cursor);\n  const slotEnd = new Date(cursor.getTime() + DURACAO_MS);\n\n  if (slotEnd \u003e toUTC(brtFimExp)) {\n    const brtNextDay = new Date(brtDay);\n    brtNextDay.setDate(brtNextDay.getDate() + 1);\n    brtNextDay.setHours(0, 0, 0, 0);\n    cursor = toUTC(brtNextDay);\n    continue;\n  }\n\n  if (!isBusy(slotStart, slotEnd)) {\n    const brtStart = toBRT(slotStart);\n    const label = DIAS[brtStart.getDay()] + \u0027 \u0027 +\n                  String(brtStart.getDate()).padStart(2, \u00270\u0027) + \u0027/\u0027 +\n                  MESES[brtStart.getMonth()] + \u0027 as \u0027 +\n                  String(brtStart.getHours()).padStart(2, \u00270\u0027) + \u0027:\u0027 +\n                  String(brtStart.getMinutes()).padStart(2, \u00270\u0027) + \u0027h\u0027;\n    slots.push({\n      isoUTC: slotStart.toISOString(),\n      isoFimUTC: slotEnd.toISOString(),\n      label\n    });\n  }\n\n  cursor = new Date(cursor.getTime() + 30 * 60 * 1000);\n}\n\nif (slots.length === 0) {\n  throw new Error(\u0027Nenhum slot disponivel na janela de 7 dias\u0027);\n}\n\nconst linhas = slots.map((s, i) =\u003e (i + 1) + \u0027. \u0027 + s.label).join(\u0027\\n\u0027);\nconst mensagemOpcoes = \u0027Otimo! Veja os horarios disponiveis para nossa call:\\n\\n\u0027 + linhas + \u0027\\n\\nResponda com 1, 2 ou 3 para confirmar o horario de sua preferencia.\u0027;\n\nreturn [{\n  json: {\n    telefone,\n    nome,\n    slots,\n    slotsJson: JSON.stringify(slots),\n    mensagemOpcoes,\n    emailLead\n  }\n}];"
                                     }
                  },
