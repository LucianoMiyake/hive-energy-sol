                  {
                      "id":  "ag-09-processa",
                      "name":  "Processa Escolha",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       500,
                                       420
                                   ],
                      "parameters":  {
                                         "jsCode":  "const data = $json.body;\nconst telefone = data.telefone;\nconst nome = data.nome;\nconst emailLead = data.email || \u0027\u0027;\nconst mensagem = (data.mensagem || \u0027\u0027).trim().toLowerCase();\n\nlet slots = [];\ntry {\n  slots = JSON.parse(data.slots_proposto || \u0027[]\u0027);\n} catch(e) {\n  slots = [];\n}\n\nlet indiceEscolha = -1;\nif (/\\b1\\b|primeiro|primeira/.test(mensagem)) indiceEscolha = 0;\nelse if (/\\b2\\b|segundo|segunda/.test(mensagem)) indiceEscolha = 1;\nelse if (/\\b3\\b|terceiro|terceira/.test(mensagem)) indiceEscolha = 2;\n\nconst escolhaValida = indiceEscolha \u003e= 0 \u0026\u0026 indiceEscolha \u003c slots.length;\n\nif (!escolhaValida) {\n  return [{ json: { telefone, nome, emailLead, escolhaValida: false } }];\n}\n\nconst slotEscolhido = slots[indiceEscolha];\nconst OFFSET_MS = 3 * 60 * 60 * 1000;\n\n// Converte UTC para BRT sem offset (formato local para Google e Outlook com timeZone especificado)\nfunction toBRTLocal(isoUTC) {\n  const d = new Date(new Date(isoUTC).getTime() - OFFSET_MS);\n  return d.toISOString().slice(0, 19);\n}\n\nconst eventoTitulo = \u0027Call Hive - \u0027 + nome;\nconst mensagemConfirmacao = \u0027Perfeito! Call agendada para \u0027 + slotEscolhido.label + \u0027.\\n\\nAte la! Se tiver qualquer duvida, e so me chamar aqui\u0027;\n\nreturn [{\n  json: {\n    telefone,\n    nome,\n    escolhaValida: true,\n    eventoTitulo,\n    eventoInicio: toBRTLocal(slotEscolhido.isoUTC),\n    eventoFim: toBRTLocal(slotEscolhido.isoFimUTC),\n    slotLabel: slotEscolhido.label,\n    mensagemConfirmacao,\n    emailLead\n  }\n}];"
                                     }
                  },
